{
  "manifest_version": 3,
  "name": "The YHC Way",
  "version": "1.0.0",
  "description": "Unified workspace for Yoga Health Center - Quick access to tasks, calendar, notifications, and AI assistant",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://yhcway.com/*",
    "https://*.yhcway.com/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "The YHC Way"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"],
      "css": ["content/gmail.css"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/capture.js"],
      "css": ["content/capture.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
